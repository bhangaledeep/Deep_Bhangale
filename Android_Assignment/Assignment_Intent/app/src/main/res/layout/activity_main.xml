<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ImageView
        android:id="@+id/defaultImage"
        android:layout_height="150dp"
        android:layout_width="150dp"
        android:src="@drawable/ic_launcher_background"
        android:layout_marginTop="80dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

    <Button
        android:id="@+id/lamborghiniButton"
        android:layout_height="wrap_content"
        android:layout_width="150dp"
        android:text="Lamborghini"
        android:textSize="15sp"
        android:textColor="@color/white"
        android:layout_marginTop="30dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        app:layout_constraintTop_toBottomOf="@+id/defaultImage"
        app:layout_constraintLeft_toLeftOf="parent"/>

    <Button
        android:id="@+id/ferrariButton"
        android:layout_height="wrap_content"
        android:layout_width="150dp"
        android:text="Ferrari"
        android:textSize="15sp"
        android:textColor="@color/white"
        android:layout_marginTop="30dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        app:layout_constraintTop_toBottomOf="@+id/defaultImage"
        app:layout_constraintRight_toRightOf="parent"/>

    <Button
        android:id="@+id/bmwButton"
        android:layout_height="wrap_content"
        android:layout_width="150dp"
        android:text="BMW"
        android:textSize="15sp"
        android:textColor="@color/white"
        android:layout_marginTop="30dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        app:layout_constraintTop_toBottomOf="@+id/lamborghiniButton"
        app:layout_constraintLeft_toLeftOf="parent"/>
